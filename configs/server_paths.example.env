# Copy this file to configs/server_paths.env on the GPU server and edit paths.
# The real configs/server_paths.env file is ignored by git.

DATA_ROOT=/path/to/mvtec_anomaly_detection
# Optional few-shot complete dataset root. When set, this replaces DATA_ROOT
# for training, hard samples, enhancer training, and evaluation.
FEW_SHOT_ROOT=
CHECKPOINT_PATH=/path/to/dinomaly_checkpoint.pth
OUTPUT_ROOT=/path/to/llm_das_dinomaly_out

# Optional overrides.
DATASET=mvtec
DINOMALY_ROOT=third_party/Dinomaly
DEVICE=cuda
RUN_MODE=smoke
BATCH_SIZE=16
MVTEC_CATEGORY=bottle
MPDD_CATEGORY=bracket_black
VISA_CATEGORY=candle
BASE_TRAIN_IF_MISSING=false
BASE_FORCE_RETRAIN=false
BASE_TOTAL_ITERS=10000
BASE_EVAL_INTERVAL=5000
BASE_CHECKPOINT_DIR=
# Few-shot defaults are intentionally shorter than full-data Dinomaly training.
FEW_SHOT_BASE_TOTAL_ITERS=2000
FEW_SHOT_BASE_EVAL_INTERVAL=1000
FEW_SHOT_ENHANCER_EPOCHS=10
MAX_SAMPLES=4
SEARCH_BUDGET=4
HARD_SAMPLE_SHARD_SIZE=32
CACHE_IMAGES=false
REGENERATE_HARD_SAMPLES=false
RETRAIN_ENHANCER=false
ENHANCER_EPOCHS=1
ENHANCER_HIDDEN_DIM=128
ENHANCER_LR=0.001
PROGRESS=true

# Evaluation overrides.
EVAL_ENABLED=true
EVAL_BATCH_SIZE=16
EVAL_NUM_WORKERS=4
EVAL_RESIZE_MASK=256
EVAL_LIMIT_PER_CATEGORY=all
EVAL_PIXEL_METRICS=true
EVAL_PIXEL_AUPRO=false
EVAL_EPOCH_PIXEL_METRICS=false
EVAL_FUSION_BETA=1.0
