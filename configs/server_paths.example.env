# Copy this file to configs/server_paths.env on the GPU server and edit paths.
# The real configs/server_paths.env file is ignored by git.

DATA_ROOT=/path/to/mvtec_anomaly_detection
CHECKPOINT_PATH=/path/to/dinomaly_checkpoint.pth
OUTPUT_ROOT=/path/to/llm_das_dinomaly_out

# Optional overrides.
DINOMALY_ROOT=third_party/Dinomaly
DEVICE=cuda
RUN_MODE=smoke
MVTEC_CATEGORY=bottle
MAX_SAMPLES=4
SEARCH_BUDGET=4
HARD_SAMPLE_SHARD_SIZE=32
CACHE_IMAGES=false
REGENERATE_HARD_SAMPLES=false
RETRAIN_ENHANCER=false
PROGRESS=true
