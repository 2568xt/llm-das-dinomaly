# Copy this file to configs/server_paths_mpdd.env on the GPU server and edit paths.
# The real configs/server_paths_mpdd.env file is ignored by git.

DATASET=mpdd
DATA_ROOT=/path/to/MPDD
CHECKPOINT_PATH=
OUTPUT_ROOT=/path/to/llm_das_dinomaly_mpdd_out

# Optional overrides.
DINOMALY_ROOT=third_party/Dinomaly
DEVICE=cuda
RUN_MODE=smoke
BATCH_SIZE=16
MPDD_CATEGORY=bracket_black
BASE_TRAIN_IF_MISSING=true
BASE_FORCE_RETRAIN=false
BASE_TOTAL_ITERS=10000
BASE_EVAL_INTERVAL=5000
BASE_CHECKPOINT_DIR=
MAX_SAMPLES=4
SEARCH_BUDGET=4
HARD_SAMPLE_SHARD_SIZE=32
CACHE_IMAGES=false
REGENERATE_HARD_SAMPLES=false
RETRAIN_ENHANCER=false
ENHANCER_EPOCHS=30
ENHANCER_HIDDEN_DIM=256
ENHANCER_LR=0.0003
PROGRESS=true

# Evaluation overrides.
EVAL_ENABLED=true
EVAL_BATCH_SIZE=16
EVAL_NUM_WORKERS=4
EVAL_RESIZE_MASK=256
EVAL_LIMIT_PER_CATEGORY=all
EVAL_PIXEL_METRICS=true
EVAL_PIXEL_AUPRO=false
EVAL_EPOCH_PIXEL_METRICS=false
EVAL_FUSION_BETA=0.5
